# Уникальное имя контейнера nginx (на всём сервере не должно повторяться)
SITE_CONTAINER_NAME=mysite_nginx

# Каталог с файлами сайта на хосте (PHP, статика)
SITE_ROOT=/opt/hosting/sites/mysite/html

# Уникальный идентификатор в Traefik (роутер + сервис), латиница, без пробелов
TRAEFIK_ROUTER=mysite

# Правило маршрутизации: домены этого сайта (см. документацию Traefik «Host»)
# Пример с www и без:
TRAEFIK_RULE=Host(`example.com`) || Host(`www.example.com`)
